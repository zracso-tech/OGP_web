---
import { getContent, PROFILE } from '../lib/content.js';
import { getCollection } from 'astro:content';
const { lang } = Astro.props;
const t = getContent(lang);
const loc = lang === 'en' ? 'en-US' : 'es-ES';

// Publicaciones (markdown en src/content/blog/)
const blogBase = lang === 'en' ? '/en/blog' : '/blog';
const blogPosts = (await getCollection('blog', (p) => p.data.lang === lang && !p.data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Titular del hero (admite formato nuevo o antiguo)
const splitVN = (s) => {
  const c = (s || '').replace(/[,.]$/, '').trim();
  const i = c.indexOf(' ');
  return i < 0 ? { verb: c, noun: '' } : { verb: c.slice(0, i), noun: c.slice(i + 1) };
};
const heroLines = t.hero.lines || [
  splitVN(t.hero.line1),
  splitVN(t.hero.line2),
  { verb: t.hero.line3a, noun: (t.hero.line3b || '').replace(/[,.]$/, '').trim() },
];

// Mapa de iconos Tabler -> Material Symbols (nombres del mockup)
const MI = {
  'ti-rocket': 'rocket_launch', 'ti-cpu': 'memory', 'ti-target-arrow': 'target',
  'ti-world': 'public', 'ti-users-group': 'groups', 'ti-chart-arrows-vertical': 'insights',
  'ti-karate': 'sports_martial_arts', 'ti-scuba-mask': 'scuba_diving',
  'ti-barbell': 'fitness_center', 'ti-guitar-pick': 'music_note',
};
const mi = (k) => MI[k] || 'auto_awesome';
const toolsGrouped = Array.isArray(t.education.tools) && typeof t.education.tools[0] !== 'string';

// Formulario de descarga de CV (bilingüe)
const cvf = lang === 'en'
  ? { title: 'Get my CV', sub: 'Fill in the form and I’ll email you my CV personally — that way I can verify your address.', first: 'First name', last: 'Last name', company: 'Company', email: 'Work email', consent: 'I agree to be contacted by Óscar González.', submit: 'Request the CV', sending: 'Sending…', ok: 'Thank you! I’ll email you my CV shortly.', err: 'Something went wrong. Please try again in a moment.' }
  : { title: 'Recibe mi CV', sub: 'Rellena el formulario y te enviaré mi CV personalmente por correo — así verifico que tu dirección es real.', first: 'Nombre', last: 'Apellidos', company: 'Empresa', email: 'Correo profesional', consent: 'Acepto ser contactado por Óscar González.', submit: 'Solicitar el CV', sending: 'Enviando…', ok: '¡Gracias! Te enviaré mi CV a tu correo en breve.', err: 'Algo ha fallado. Inténtalo de nuevo en un momento.' };

const calEmbed = `
(function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if (typeof namespace === "string") { cal.ns[namespace] = cal.ns[namespace] || api; p(cal.ns[namespace], ar); p(cal, ["initNamespace", namespace]); } else p(cal, ar); return; } p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
Cal("init", "ogp", { origin: "https://cal.com" });
Cal.ns.ogp("inline", { elementOrSelector: "#cal-inline", calLink: "${PROFILE.calLink}", layout: "month_view" });
Cal.ns.ogp("ui", { theme: "light", cssVarsPerTheme: { light: { "cal-brand": "#1b2a4a" } }, hideEventTypeDetails: false, layout: "month_view" });
`;
---

<!-- ============ HERO ============ -->
<section id="inicio" class="relative min-h-screen flex flex-col pt-20 overflow-hidden" style="background: radial-gradient(circle at 72% 28%, #ece6d4 0%, #f4f0e5 58%);">
  <div class="flex-1 flex items-center w-full">
    <div class="max-w-container-max mx-auto w-full px-margin-mobile md:px-gutter grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
      <div class="md:col-span-8 flex flex-col gap-7">
        <div class="flex flex-col gap-3">
          <span class="text-secondary font-label-caps text-label-caps uppercase tracking-[0.18em]">{t.hero.role}</span>
          <h1 class="font-display-xl-mobile md:text-display-xl md:font-display-xl leading-[1.02] flex flex-col text-primary">
            {heroLines.map((l, i) => (
              <span class={i === 1 ? 'text-secondary italic' : ''} data-split>{[l.verb, l.noun].filter(Boolean).join(' ')}</span>
            ))}
          </h1>
        </div>
        <div class="flex flex-wrap gap-3">
          {t.hero.tags.map((tag) => (
            <span class="px-4 py-1.5 border border-on-surface-variant/25 text-on-surface-variant font-label-caps text-label-caps rounded-full">{tag}</span>
          ))}
        </div>
        <div class="flex flex-wrap gap-4 mt-2">
          <a href="#contacto" data-magnetic class="bg-primary text-on-primary px-9 py-4 font-label-caps text-label-caps hover:bg-primary-container transition-colors uppercase tracking-widest">{t.ui.bookMeeting}</a>
          <button type="button" data-cv-open class="border border-secondary text-secondary px-9 py-4 font-label-caps text-label-caps hover:bg-secondary/10 transition-colors uppercase tracking-widest">{t.ui.downloadCv}</button>
        </div>
      </div>
      <div class="md:col-span-4 relative" data-cursor>
        <div class="aspect-[4/5] w-full bg-surface-container/60 relative overflow-hidden group">
          <img src="/images/oscar-pro.png" alt="Óscar González Pérez" class="w-full h-full object-contain object-bottom grayscale group-hover:grayscale-0 transition-all duration-700" />
          <div class="absolute inset-0 border border-secondary/30 m-4 pointer-events-none"></div>
        </div>
      </div>
    </div>
  </div>
  <!-- Metrics band -->
  <div class="bg-primary py-7 md:py-8">
    <div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter grid grid-cols-3" data-reveal-group>
      {t.hero.metrics.map((m, i) => (
        <div class={`flex flex-col gap-1 px-3 md:px-8 ${i > 0 ? 'border-l border-on-primary/15' : ''}`} data-reveal-item>
          <span class="text-on-primary font-headline-md text-2xl md:text-headline-md">
            {typeof m.value === 'number' ? (
              <><span data-count={m.value} data-locale={loc}>0</span><span class="text-secondary-fixed"> {m.suffix}</span></>
            ) : (<span>{m.value}</span>)}
          </span>
          <span class="text-on-primary-container font-label-caps text-[10px] md:text-label-caps uppercase">{m.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============ SOBRE MÍ ============ -->
<section id="presentacion" class="py-section-gap-mobile md:py-section-gap-desktop bg-surface">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16">
    <div class="md:col-span-5" data-reveal>
      <span class="text-secondary font-label-caps text-label-caps uppercase tracking-[0.18em]">{t.nav[1].label}</span>
      <h2 class="font-headline-lg-mobile md:text-headline-lg md:font-headline-lg text-primary leading-tight mt-5">{t.about.title}</h2>
      <div class="mt-8 h-1 w-20 bg-secondary"></div>
    </div>
    <div class="md:col-span-7 flex flex-col gap-6 text-on-surface-variant font-body-lg text-body-lg" data-reveal>
      {t.about.paragraphs.map((p) => <p>{p}</p>)}
    </div>
  </div>
</section>

<!-- ============ LADO PERSONAL ============ -->
<section id="personal" class="py-section-gap-mobile md:py-section-gap-desktop bg-surface-container-lowest">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter">
    <div class="flex flex-col gap-3 mb-14" data-reveal>
      <span class="text-secondary font-label-caps text-label-caps uppercase tracking-[0.18em]">{t.personal.title}</span>
      <h2 class="font-headline-lg-mobile md:text-headline-lg md:font-headline-lg text-primary">{t.personal.lead}</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6" data-reveal-group>
      {t.personal.items.map((h) => (
        <div class="group border border-on-surface-variant/15 p-8 flex flex-col gap-10 hover:border-secondary transition-all duration-300" data-reveal-item>
          <div class="flex flex-col gap-4">
            <span class="material-symbols-outlined text-4xl text-primary">{mi(h.icon)}</span>
            <h3 class="font-headline-md text-headline-md text-primary">{h.name}</h3>
          </div>
          <div class="flex flex-col gap-2">
            <p class="text-on-surface-variant text-body-md">{h.value}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============ COMPETENCIAS (oscuro) ============ -->
<section id="competencias" class="py-section-gap-mobile md:py-section-gap-desktop bg-primary text-on-primary">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter">
    <div class="flex flex-col gap-3 mb-14" data-reveal>
      <span class="text-secondary-fixed font-label-caps text-label-caps uppercase tracking-[0.18em]">{t.nav[2].label}</span>
      <h2 class="font-headline-lg-mobile md:text-headline-lg md:font-headline-lg text-on-primary">{t.competencies.title}</h2>
      <p class="text-on-primary-container font-body-lg text-body-lg max-w-2xl mt-2">{t.competencies.lead}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-y-14 gap-x-12" data-reveal-group>
      {t.competencies.items.map((c) => (
        <div class="flex flex-col gap-5" data-reveal-item>
          <div class="w-12 h-12 flex items-center justify-center bg-secondary-fixed/10 text-secondary-fixed rounded-full">
            <span class="material-symbols-outlined text-3xl">{mi(c.icon)}</span>
          </div>
          <h3 class="font-headline-md text-headline-md">{c.title}</h3>
          <p class="text-on-primary-container text-body-md">{c.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============ TRAYECTORIA ============ -->
<section id="experiencia" class="py-section-gap-mobile md:py-section-gap-desktop bg-surface overflow-hidden">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter">
    <div class="flex flex-col md:flex-row justify-between md:items-end gap-6 mb-12" data-reveal>
      <div class="flex flex-col gap-3">
        <span class="text-secondary font-label-caps text-label-caps uppercase tracking-[0.18em]">{t.nav[3].label}</span>
        <h2 class="font-headline-lg-mobile md:text-headline-lg md:font-headline-lg text-primary">{t.experience.title}</h2>
      </div>
      <div class="flex gap-4">
        <button class="w-12 h-12 flex items-center justify-center border border-outline hover:bg-secondary hover:text-on-secondary hover:border-secondary transition-all rounded-full" aria-label="Anterior" onclick="document.getElementById('timeline').scrollBy({left: -440, behavior:'smooth'})"><span class="material-symbols-outlined">arrow_back</span></button>
        <button class="w-12 h-12 flex items-center justify-center border border-outline hover:bg-secondary hover:text-on-secondary hover:border-secondary transition-all rounded-full" aria-label="Siguiente" onclick="document.getElementById('timeline').scrollBy({left: 440, behavior:'smooth'})"><span class="material-symbols-outlined">arrow_forward</span></button>
      </div>
    </div>
  </div>
  <div id="timeline" class="flex gap-8 overflow-x-auto pb-10 snap-x scroll-px-6 px-margin-mobile md:px-[max(24px,calc((100vw-1280px)/2))]">
    {t.experience.items.map((it) => (
      <article class="min-w-[340px] sm:min-w-[400px] max-w-[400px] flex-shrink-0 bg-white p-8 border-t-2 border-secondary snap-start flex flex-col gap-5 shadow-[0_20px_40px_rgba(27,42,74,0.05)]">
        <div class="text-on-surface-variant font-label-caps text-label-caps uppercase">{it.period}</div>
        <div class="flex flex-col gap-1">
          <h3 class="font-headline-md text-headline-md text-primary leading-tight">{it.role}</h3>
          <span class="text-secondary font-medium">{it.company}</span>
        </div>
        <div class="text-body-md text-on-surface-variant italic border-l-2 border-outline-variant pl-4">{it.report}</div>
        <div class="flex flex-col gap-3">
          <h4 class="font-label-caps text-label-caps text-primary uppercase">{t.experience.actionLabel}</h4>
          <p class="text-body-md text-on-surface-variant">{it.action}</p>
        </div>
        {it.facts && (
          <div class="grid grid-cols-3 gap-2">
            {it.facts.map((f) => (
              <div class="flex flex-col items-center text-center gap-1 p-3 bg-surface rounded">
                <span class="material-symbols-outlined text-secondary">{mi(f.icon)}</span>
                <span class="text-[11px] text-on-surface-variant leading-tight">{f.text}</span>
              </div>
            ))}
          </div>
        )}
        <div class="flex flex-col gap-3">
          <h4 class="font-label-caps text-label-caps text-primary uppercase">{t.experience.resultsLabel}</h4>
          <ul class="flex flex-col gap-2">
            {it.results.map((r) => (
              <li class="flex items-start gap-2 text-body-md text-on-surface-variant">
                <span class="material-symbols-outlined text-secondary text-lg leading-6">check_circle</span><span>{r}</span>
              </li>
            ))}
          </ul>
        </div>
      </article>
    ))}
  </div>
</section>

<!-- ============ FORMACIÓN ============ -->
<section id="formacion" class="py-section-gap-mobile md:py-section-gap-desktop bg-surface-container-low">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter">
    <div class="flex flex-col gap-3 mb-14" data-reveal>
      <span class="text-secondary font-label-caps text-label-caps uppercase tracking-[0.18em]">{t.nav[4].label}</span>
      <h2 class="font-headline-lg-mobile md:text-headline-lg md:font-headline-lg text-primary">{t.education.title}</h2>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-14">
      <div class="flex flex-col gap-12" data-reveal>
        <div class="flex flex-col gap-7">
          <h3 class="font-headline-md text-headline-md text-primary flex items-center gap-3"><span class="material-symbols-outlined">school</span>{t.education.studyTitle}</h3>
          <div class="flex flex-col gap-4">
            {t.education.study.map((s) => (
              <div class="bg-white p-6 shadow-[0_10px_30px_rgba(27,42,74,0.04)]">
                <h4 class="font-headline-md text-primary">{s.name}</h4>
                <p class="text-on-surface-variant text-body-md mt-1">{s.org}</p>
                {s.note && <p class="text-on-surface-variant/80 text-sm mt-2">{s.note}</p>}
              </div>
            ))}
          </div>
        </div>
        <div class="flex flex-col gap-7">
          <h3 class="font-headline-md text-headline-md text-primary flex items-center gap-3"><span class="material-symbols-outlined">workspace_premium</span>{t.education.certsTitle}</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {t.education.certs.map((c) => (
              <div class="border border-on-surface-variant/20 p-4 text-on-surface-variant text-body-md">{c}</div>
            ))}
          </div>
        </div>
      </div>
      <div class="flex flex-col gap-12" data-reveal>
        <div class="flex flex-col gap-7">
          <h3 class="font-headline-md text-headline-md text-primary flex items-center gap-3"><span class="material-symbols-outlined">handyman</span>{t.education.toolsTitle}</h3>
          <div class="flex flex-col gap-5">
            {toolsGrouped ? t.education.tools.map((g) => (
              <div class="flex flex-col gap-2">
                <span class="text-secondary font-label-caps text-label-caps uppercase">{g.group}</span>
                <div class="flex flex-wrap gap-2">
                  {g.items.map((tool) => <span class="bg-primary/[0.06] px-3 py-1 text-on-surface-variant text-sm">{tool}</span>)}
                </div>
              </div>
            )) : (
              <div class="flex flex-wrap gap-2">
                {t.education.tools.map((tool) => <span class="bg-primary/[0.06] px-3 py-1 text-on-surface-variant text-sm">{tool}</span>)}
              </div>
            )}
          </div>
        </div>
        <div class="flex flex-col gap-7">
          <h3 class="font-headline-md text-headline-md text-primary flex items-center gap-3"><span class="material-symbols-outlined">language</span>{t.education.langTitle}</h3>
          <div class="flex flex-col gap-6">
            {t.education.languages.map((l) => (
              <div class="flex flex-col gap-2">
                <div class="flex justify-between items-center">
                  <span class="text-primary font-medium">{l.name}</span>
                  <span class="text-on-surface-variant font-label-caps text-label-caps">{l.level}</span>
                </div>
                <div class="w-full h-1 bg-on-surface-variant/20"><div class="h-full bg-secondary" data-bar={l.pct} style={`width:${l.pct}%`}></div></div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ PUBLICACIONES ============ -->
<section id="publicaciones" class="py-section-gap-mobile md:py-section-gap-desktop bg-surface">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter">
    <div class="flex flex-col gap-3 mb-14 text-center items-center" data-reveal>
      <span class="text-secondary font-label-caps text-label-caps uppercase tracking-[0.18em]">{t.nav[5].label}</span>
      <h2 class="font-headline-lg-mobile md:text-headline-lg md:font-headline-lg text-primary">{t.publications.title}</h2>
      <p class="text-on-surface-variant font-body-lg text-body-lg max-w-2xl">{t.publications.lead}</p>
    </div>
    {blogPosts.length === 0 && <p class="text-center text-on-surface-variant">{t.publications.soon}</p>}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-reveal-group>
      {blogPosts.map((p) => (
        <a class="group flex flex-col" href={`${blogBase}/${p.id.split('/').pop()}/`} data-reveal-item>
          <div class="aspect-video mb-6 relative overflow-hidden bg-surface-container">
            {p.data.image && <img alt={p.data.title} loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src={p.data.image} />}
          </div>
          <span class="text-secondary font-label-caps text-label-caps uppercase">{p.data.tag}</span>
          <h3 class="font-headline-md text-headline-md text-primary mt-2 group-hover:text-secondary transition-colors">{p.data.title}</h3>
          <p class="text-on-surface-variant text-body-md mt-3">{p.data.excerpt}</p>
          <span class="mt-4 text-secondary font-label-caps text-label-caps uppercase inline-flex items-center gap-2">{t.publications.readMore}<span class="material-symbols-outlined text-base">arrow_forward</span></span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ============ AGENDA (calendario) ============ -->
<section id="contacto" class="py-section-gap-mobile md:py-section-gap-desktop bg-surface-container-highest">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
    <div class="lg:col-span-5 flex flex-col gap-6" data-reveal>
      <span class="text-secondary font-label-caps text-label-caps uppercase tracking-[0.18em]">{t.nav[6].label}</span>
      <h2 class="font-headline-lg-mobile md:text-headline-lg md:font-headline-lg text-primary">{t.contact.title}</h2>
      <p class="text-body-lg text-on-surface-variant">{t.contact.lead}</p>
      <div class="flex flex-col gap-4 mt-2">
        <div class="flex items-center gap-3"><span class="material-symbols-outlined text-secondary">location_on</span><span class="text-on-surface-variant">{PROFILE.location}</span></div>
        <a class="flex items-center gap-3 text-on-surface-variant hover:text-secondary transition-colors" href={PROFILE.cal} target="_blank" rel="noopener"><span class="material-symbols-outlined text-secondary">open_in_new</span><span>{t.contact.cta}</span></a>
      </div>
    </div>
    <div class="lg:col-span-7 bg-white p-3 sm:p-4 shadow-[0_20px_50px_rgba(27,42,74,0.1)] w-full" data-reveal>
      <div id="cal-inline" class="w-full min-h-[640px] rounded"></div>
    </div>
  </div>
  <script is:inline set:html={calEmbed}></script>
</section>

<!-- ============ CONTACTO (oscuro) ============ -->
<section id="hablemos" class="py-section-gap-mobile md:py-section-gap-desktop bg-primary text-on-primary">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter">
    <div class="flex flex-col gap-3 mb-12" data-reveal>
      <span class="text-secondary-fixed font-label-caps text-label-caps uppercase tracking-[0.18em]">{t.nav[7].label}</span>
      <h2 class="font-headline-lg-mobile md:text-headline-lg md:font-headline-lg text-on-primary">{t.talk.title}</h2>
      <p class="text-on-primary-container font-body-lg text-body-lg max-w-2xl mt-2">{t.talk.lead}</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6" data-reveal-group>
      <a class="p-8 border border-on-primary/10 hover:border-secondary-fixed transition-colors flex flex-col gap-4" href={`mailto:${PROFILE.email}`} data-reveal-item>
        <span class="material-symbols-outlined text-secondary-fixed text-3xl">mail</span>
        <span class="font-label-caps text-label-caps uppercase text-on-primary-container">{t.talk.emailLabel}</span>
        <span class="font-headline-md text-on-primary break-words">{PROFILE.email}</span>
      </a>
      <a class="p-8 border border-on-primary/10 hover:border-secondary-fixed transition-colors flex flex-col gap-4" href={`tel:${PROFILE.phoneHref}`} data-reveal-item>
        <span class="material-symbols-outlined text-secondary-fixed text-3xl">call</span>
        <span class="font-label-caps text-label-caps uppercase text-on-primary-container">{t.talk.phoneLabel}</span>
        <span class="font-headline-md text-on-primary">{PROFILE.phone}</span>
      </a>
      <a class="p-8 border border-on-primary/10 hover:border-secondary-fixed transition-colors flex flex-col gap-4" href={PROFILE.linkedin} target="_blank" rel="noopener" data-reveal-item>
        <span class="material-symbols-outlined text-secondary-fixed text-3xl">share</span>
        <span class="font-label-caps text-label-caps uppercase text-on-primary-container">{t.talk.linkedinLabel}</span>
        <span class="font-headline-md text-on-primary break-words">/in/oscargonzalezperez</span>
      </a>
      <div class="p-8 border border-on-primary/10 flex flex-col gap-4" data-reveal-item>
        <span class="material-symbols-outlined text-secondary-fixed text-3xl">location_city</span>
        <span class="font-label-caps text-label-caps uppercase text-on-primary-container">{t.talk.locationLabel}</span>
        <span class="font-headline-md text-on-primary">{PROFILE.location}</span>
      </div>
    </div>
  </div>
</section>

<!-- ============ MODAL: RECIBIR CV ============ -->
<div class="cvmodal" data-cv-modal hidden>
  <div class="cvmodal__overlay" data-cv-close></div>
  <div class="cvmodal__card" role="dialog" aria-modal="true" aria-labelledby="cvmodal-title">
    <button type="button" class="cvmodal__x" data-cv-close aria-label="Cerrar"><i class="ti ti-x" aria-hidden="true"></i></button>
    <div class="cvmodal__icon"><i class="ti ti-file-cv" aria-hidden="true"></i></div>
    <h3 id="cvmodal-title" class="cvmodal__title">{cvf.title}</h3>
    <p class="cvmodal__sub">{cvf.sub}</p>
    <form class="cvform" data-cv-form data-ok={cvf.ok} data-err={cvf.err} data-sending={cvf.sending} data-endpoint={`https://formsubmit.co/ajax/${PROFILE.email}`}>
      <input type="hidden" name="_subject" value="📄 Nueva solicitud de CV desde la web" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="lang" value={lang} />
      <input type="text" name="_honey" class="cvform__hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <div class="cvform__row">
        <label class="cvform__field"><span>{cvf.first}</span><input type="text" name="firstName" autocomplete="given-name" required /></label>
        <label class="cvform__field"><span>{cvf.last}</span><input type="text" name="lastName" autocomplete="family-name" required /></label>
      </div>
      <label class="cvform__field"><span>{cvf.company}</span><input type="text" name="company" autocomplete="organization" required /></label>
      <label class="cvform__field"><span>{cvf.email}</span><input type="email" name="email" autocomplete="email" required /></label>
      <label class="cvform__consent"><input type="checkbox" name="consent" required /><span>{cvf.consent}</span></label>
      <button type="submit" class="btn btn--gold cvform__submit">{cvf.submit}</button>
      <p class="cvform__msg" data-cv-msg aria-live="polite"></p>
    </form>
  </div>
</div>
